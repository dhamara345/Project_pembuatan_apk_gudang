	<field name="id_kabel" class="java.lang.String"/>
	<field name="panjang_kabel" class="java.lang.String"/>
	<field name="jenis_kabel" class="java.lang.String"/>
	<field name="tipe_kabel" class="java.lang.String"/>
	<title>
		<band height="80" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="10" width="555" height="35"/>
