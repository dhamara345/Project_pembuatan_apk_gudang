		</band>
	</title>
	<detail>
		<band height="120" splitType="Stretch">
			<staticText><reportElement x="50" y="10" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[ID Kabel]]></text></staticText>
			<textField><reportElement x="210" y="10" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{id_kabel}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="35" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Panjang Kabel]]></text></staticText>
			<textField><reportElement x="210" y="35" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{panjang_kabel}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="60" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Jenis Kabel]]></text></staticText>
