<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="report_client" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<queryString>
		<![CDATA[SELECT id_client, nama_perusahaan, alamat_client, no_telepon, nama_PIC FROM client]]>
	</queryString>
	<field name="id_client" class="java.lang.String"/>
	<field name="nama_perusahaan" class="java.lang.String"/>
	<field name="alamat_client" class="java.lang.String"/>
	<field name="no_telepon" class="java.lang.String"/>
	<field name="nama_PIC" class="java.lang.String"/>
	<title>
		<band height="80" splitType="Stretch">
			<staticText>
				<reportElement x="0" y="10" width="555" height="35"/>
				<textElement textAlignment="Center"><font size="22" isBold="true"/></textElement>
				<text><![CDATA[LAPORAN DATA MITRA CLIENT GUDANG]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="45" width="555" height="20"/>
				<textElement textAlignment="Center"><font size="11" isItalic="true"/></textElement>
				<text><![CDATA[Sistem Informasi Manajemen Stok Kelompok 3]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="65" width="555" height="15"/>
				<textElement textAlignment="Center"/>
				<text><![CDATA[================================================================]]></text>
			</staticText>
		</band>
	</title>
	<detail>
		<band height="145" splitType="Stretch">
			<staticText><reportElement x="50" y="10" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[ID Client]]></text></staticText>
			<textField><reportElement x="210" y="10" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{id_client}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="35" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Nama Perusahaan]]></text></staticText>
			<textField><reportElement x="210" y="35" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{nama_perusahaan}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="60" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Alamat Client]]></text></staticText>
			<textField><reportElement x="210" y="60" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{alamat_client}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="85" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[No. Telepon]]></text></staticText>
			<textField><reportElement x="210" y="85" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{no_telepon}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="110" width="140" height="20"/><textElement><font size="11" isBold="true"/></textElement><text><![CDATA[Nama PIC]]></text></staticText>
			<textField><reportElement x="210" y="110" width="300" height="20"/><textElement><font size="11"/></textElement><textFieldExpression><![CDATA[": " + $F{nama_PIC}]]></textFieldExpression></textField>
			
			<staticText><reportElement x="50" y="130" width="440" height="15"/><text><![CDATA[-------------------------------------------------------------------------------------------------------------------------]]></text></staticText>
		</band>
	</detail>
</jasperReport>